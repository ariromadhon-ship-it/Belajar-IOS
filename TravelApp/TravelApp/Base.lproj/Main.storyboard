<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder.iPhone.Storyboard" version="3.0" toolsVersion="21701" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorLaunchImage="YES">
    <device id="retina6_1" orientation="portrait" appearance="light"/>
    <dependencies>
